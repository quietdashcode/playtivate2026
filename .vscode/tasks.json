{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "install dependencies",
			"type": "shell",
			"command": "npm",
			"args": [
				"install"
			],
			"isBackground": false
		},
		{
			"label": "dev server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--host"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "build site",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}